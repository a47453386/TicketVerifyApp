<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/pixel_bg_dark">

    <LinearLayout
        android:id="@+id/layout_navbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111111"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="4dp"
            android:weightSum="6">
        </LinearLayout>
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/pixel_blue"/>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/content_frame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layout_navbar"
        android:layout_above="@+id/layout_status_bar"
        android:layout_margin="16dp"
        android:background="@drawable/layer_list"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ 通行權限驗證 ]"
                android:textColor="@color/pixel_pink"
                android:textSize="22sp"
                android:fontFamily="monospace"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/btnOpenScanner"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="QR_CODE掃描"
                android:fontFamily="monospace"
                android:textSize="24sp"
                android:backgroundTint="@color/pixel_blue"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">> 手動代碼輸入:"
                android:textColor="@color/pixel_blue"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:layout_gravity="start" />
            <EditText
                android:id="@+id/etCheckInCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="請輸入檢查碼"
                android:textColorHint="#444444"
                android:textColor="@color/pixel_pink"
                android:backgroundTint="@color/pixel_pink"
                android:fontFamily="monospace"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnVerify"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="執行"
                android:fontFamily="monospace"
                android:backgroundTint="@color/pixel_pink" />

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="#1A1A1A"
                android:padding="12dp"
                android:text="系統已就緒..."
                android:textColor="@color/pixel_blue"
                android:fontFamily="monospace"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

    <LinearLayout
        android:id="@+id/layout_status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#000000"
        android:padding="6dp"
        android:gravity="center">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● SYSTEM: ONLINE | AUTH: VERIFIED"
            android:textColor="@color/pixel_blue"
            :textSize="9sp"
            android:fontFamily="monospace" />
    </LinearLayout>
</RelativeLayout>